---
- name: Preflight checks (no changes)
  hosts: k8s
  become: true
  roles:
    - { role: preflight, tags: ["preflight"] }

- name: Common OS prep + container runtime + Kubernetes packages
  hosts: k8s
  become: true
  roles:
    - { role: common,     tags: ["common"] }
    - { role: containerd, tags: ["containerd"] }
    - { role: kubernetes, tags: ["kubernetes"] }

- name: Initialize control plane + install CNI
  hosts: controlplane
  become: true
  roles:
    - { role: controlplane, tags: ["controlplane"] }
    - { role: cni_calico,   tags: ["cni"] }

- name: Join worker nodes
  hosts: workers
  become: true
  roles:
    - { role: workers, tags: ["workers"] }

- name: Install local StorageClass provisioner
  hosts: controlplane
  become: true
  roles:
    - { role: local_storageclass, tags: ["storageclass"] }

- name: Deploy MinIO
  hosts: controlplane
  become: true
  roles:
    - { role: minio_deploy, tags: ["minio"] }

- name: Deploy Grafana Mimir with Helm
  hosts: controlplane
  become: true
  roles:
    - { role: mimir_deploy, tags: ["mimir"] }

- name: Deploy ingress-nginx
  hosts: controlplane
  become: true
  roles:
    - { role: ingress_nginx, tags: ["ingress-nginx"] }

- name: Expose Mimir gateway through ingress
  hosts: controlplane
  become: true
  roles:
    - { role: mimir_ingress, tags: ["mimir-ingress"] }
